# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
SECRET_KEY=changeme-generate-with-secrets-token-hex-32
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# MongoDB
MONGODB_URL=mongodb://notifyhq:notifyhq_secret@localhost:27017/notifyhq?authSource=admin
MONGODB_DB_NAME=notifyhq

# RabbitMQ
RABBITMQ_URL=amqp://notifyhq:notifyhq_secret@localhost:5672/

# 3rd Party Providers (filled in when Module 10 is reached)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
